{
  "name": "tobacco-tracker-root",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "preinstall": "cd nextjs && (npm ci || npm install)",
    "build": "cd nextjs && npm run build",
    "start": "cd nextjs && npm run start",
    "pages:build": "cd nextjs && npm run pages:build",
    "cf:deploy": "npx wrangler pages deploy nextjs/.vercel/output/static",
    "cf:deploy:dry-run": "npx wrangler pages deploy nextjs/.vercel/output/static --dry-run",
    "d1:init": "npx wrangler d1 execute tobacco-tracker --file=sql/schema.d1.sql",
    "d1:init:local": "npx wrangler d1 execute tobacco-tracker --local --file=sql/schema.d1.sql",
    "mcp:cloudflare-worker": "npm --prefix mcp/cloudflare-worker start",
    "mcp:cloudflare-worker:install": "npm install --prefix mcp/cloudflare-worker"
  }
}
